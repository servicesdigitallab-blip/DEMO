:root {
    --bg-main: #FAFAFA;
    --bg-alt: #F4F0EB;
    --text-dark: #111111;
    --text-light: #666666;
    --accent: #B09270; /* Soft gold/beige */
    --white: #FFFFFF;
    
    --font-serif: 'Playfair Display', serif;
    --font-sans: 'Inter', sans-serif;
    
    --ease: cubic-bezier(0.22, 1, 0.36, 1);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: var(--font-sans);
    background-color: var(--bg-main);
    color: var(--text-dark);
    line-height: 1.6;
    overflow-x: hidden;
    opacity: 0; /* Fade in via JS */
}

img {
    max-width: 100%;
    display: block;
}

/* TYPOGRAPHY */
h1, h2, h3, h4, h5, .logo {
    font-family: var(--font-serif);
    font-weight: 500;
}

.accent-text {
    color: var(--accent);
}

.subtitle {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 10px;
    font-weight: 500;
}

.title {
    font-size: 3.5rem;
    line-height: 1.2;
    margin-bottom: 20px;
}

.center {
    text-align: center;
}

/* BUTTONS */
button {
    font-family: var(--font-sans);
    cursor: pointer;
    border: none;
    outline: none;
    transition: all 0.3s var(--ease);
}

.btn-solid {
    background-color: var(--text-dark);
    color: var(--white);
    padding: 16px 32px;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid var(--text-dark);
}

.btn-solid:hover {
    background-color: var(--accent);
    border-color: var(--accent);
}

.btn-outline {
    background-color: transparent;
    color: var(--text-dark);
    padding: 16px 32px;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid var(--text-dark);
}

.btn-outline:hover {
    background-color: var(--text-dark);
    color: var(--white);
}

.full-width {
    width: 100%;
}

.mt-4 {
    margin-top: 24px;
}

/* PREMIUM NAVBAR */
.navbar-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 2000;
    padding: 0; /* Fixed the top gap button-like look */
    transition: all 0.5s cubic-bezier(0.2, 1, 0.3, 1);
}

.navbar-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 15px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: all 0.5s cubic-bezier(0.2, 1, 0.3, 1);
    border-radius: 0;
}

/* INITIAL STATE: OVER HERO */
.navbar-logo a {
    font-size: 20px;
    letter-spacing: 5px;
    font-weight: 800;
    color: #000;
    text-decoration: none;
    transition: opacity 0.3s ease;
}

.navbar-logo a:hover {
    opacity: 0.7;
}

.navbar-menu {
    display: flex;
    gap: 35px;
}

.navbar-menu a {
    text-decoration: none;
    color: #000;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 600;
    position: relative;
    padding: 5px 0;
    transition: color 0.3s ease;
}

.navbar-menu a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1.5px;
    background: #000;
    transition: width 0.3s ease;
}

.navbar-menu a:hover::after {
    width: 100%;
}

.navbar-menu a.active::after {
    width: 100%;
    background: #888;
}

.navbar-actions {
    display: flex;
    align-items: center;
    gap: 25px;
}

.btn-book-outline {
    background: transparent;
    color: #000;
    border: 1px solid #000;
    padding: 12px 24px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 600;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-book-outline:hover {
    transform: scale(1.05);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.mobile-toggle {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    flex-direction: column;
    gap: 6px;
    transition: transform 0.3s ease;
}

.mobile-toggle:hover {
    transform: rotate(5deg);
}

.mobile-toggle .line {
    width: 25px;
    height: 2px;
    background: #000;
    transition: 0.3s;
}

/* SCROLLED STATE */
.navbar-wrapper.scrolled {
    padding: 15px 20px;
    animation: navAppear 0.4s forwards;
}

@keyframes navAppear {
    from { transform: translateY(-20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.navbar-wrapper.scrolled .navbar-container {
    background: #ffffff;
    backdrop-filter: none;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border-radius: 16px;
    padding: 12px 35px;
}

.navbar-wrapper.scrolled .btn-book-outline {
    background: #000;
    color: #fff;
    border-color: #000;
}

/* MOBILE OVERLAY */
.mobile-menu-overlay {
    position: fixed;
    top: 0;
    right: -100%;
    width: 100%;
    height: 100%;
    background: #fff;
    z-index: 3000;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 40px;
    transition: right 0.5s cubic-bezier(0.77,0.2,0.05,1);
    visibility: hidden;
}

.mobile-menu-overlay.active {
    right: 0;
    visibility: visible;
}

.close-mobile-menu {
    position: absolute;
    top: 30px;
    right: 40px;
    font-size: 40px;
    background: transparent;
    border: none;
    cursor: pointer;
}

.mobile-menu-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 25px;
}

.mobile-menu-links a {
    text-decoration: none;
    color: #000;
    font-size: 24px;
    text-transform: uppercase;
    letter-spacing: 4px;
    font-weight: 700;
}

.btn-book-solid {
    background: #000;
    color: #fff;
    border: none;
    padding: 18px 35px;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    border-radius: 50px;
    cursor: pointer;
}

@media (max-width: 992px) {
    .navbar-menu {
        display: none;
    }
    
    .btn-book-outline {
        display: none;
    }
    
    .mobile-toggle {
        display: flex;
    }
    
    .navbar-container {
        padding: 12px 25px;
    }
}

/* MULTI-STEP FORM STYLES */
.form-steps-container {
    position: relative;
    overflow: hidden;
}

.form-step {
    display: none;
    animation: fadeIn 0.5s ease forwards;
}

.form-step.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.step-btns {
    display: flex;
    gap: 15px;
    margin-top: 25px;
}

.btn-outline {
    background: transparent;
    border: 1px solid rgba(0,0,0,0.1);
    color: var(--text-dark);
    padding: 12px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-outline:hover {
    background: rgba(0,0,0,0.02);
    border-color: var(--text-dark);
}

.full-width {
    width: 100%;
}

.mt-4 {
    margin-top: 1.5rem !important;
}

/* SUCCESS POPUP */
.thanks-popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(8px);
    z-index: 9999;
    display: none; /* Controlled by JS */
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.thanks-popup-overlay.show {
    display: flex;
}

.thanks-card {
    background: white;
    padding: 50px 40px;
    border-radius: 24px;
    text-align: center;
    max-width: 500px;
    width: 100%;
    box-shadow: 0 30px 60px rgba(0,0,0,0.3);
    animation: popupSlideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes popupSlideUp {
    from { opacity: 0; transform: translateY(50px) scale(0.9); }
    to { opacity: 1; transform: translateY(0) scale(1); }
}

.thanks-card i {
    font-size: 60px;
    color: #4CAF50;
    margin-bottom: 25px;
}

.thanks-card h2 {
    font-family: var(--font-serif);
    font-size: 32px;
    margin-bottom: 15px;
}

.thanks-card p {
    color: var(--text-light);
    line-height: 1.6;
    margin-bottom: 30px;
}

.btn-close-popup {
    background: var(--text-dark);
    color: white;
    border: none;
    padding: 14px 35px;
    border-radius: 50px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.3s ease;
}

.btn-close-popup:hover {
    transform: scale(1.05);
}

/* SECTION 1: HERO */
.hero-section.immersive-hero {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
}

.hero-bg-wrapper {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
}

.hero-bg-full {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: heroZoom 20s infinite alternate ease-in-out;
}

.hero-content.left-box {
    position: relative;
    z-index: 10;
    width: 100%;
    height: 100%;
    background: transparent;
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Align content to bottom */
    padding: 0 5% 100px 8%;
}

.hero-text-wrap {
    position: relative;
    width: 100%;
}

.hero-btns-group {
    position: absolute !important;
    bottom: 80px !important; 
    left: 8% !important;
    display: flex !important;
    gap: 20px !important;
    z-index: 99999 !important; /* Extremely high to ensure clickability */
    opacity: 0.01 !important; /* Practically invisible but browser-detectable for clicks */
    pointer-events: auto !important;
}

.hero-btns-group button {
    width: 180px !important; 
    height: 60px !important; 
    background: rgba(0,0,0,0) !important;
    border: none !important;
    cursor: pointer !important;
    display: block !important;
}

.btn-solid-hero {
    background: #000;
    color: #fff;
    padding: 16px 40px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
    border: 1px solid #000;
    width: fit-content;
    border-radius: 4px;
    transition: all 0.3s ease;
}

.btn-outline-hero {
    background: #fff; /* White background as per screenshot */
    color: #000;
    padding: 16px 40px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
    border: 1px solid #000;
    width: fit-content;
    border-radius: 4px;
    transition: all 0.3s ease;
}

.btn-solid-hero:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
.btn-outline-hero:hover { background: #000; color: #fff; }

.hero-buttons {
    display: flex;
    gap: 20px;
}

@keyframes heroZoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.04); }
}

/* SECTION 2: PROJECTS */
.projects-section {
    padding: 120px 0;
    background-color: var(--bg-main);
    overflow: hidden;
}

.carousel-container {
    margin-top: 60px;
    width: 100%;
}

.carousel-track {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 0 50%; /* Large padding to allow centering first/last */
    transition: transform 0.6s var(--ease);
    will-change: transform;
}

.project-card {
    flex-shrink: 0;
    transition: all 0.5s var(--ease);
}

.project-card.side {
    width: 280px;
    opacity: 0.5 !important;
    transform: scale(0.9);
    text-align: left;
}

.project-card.active {
    width: 800px;
    opacity: 1 !important;
    transform: scale(1);
}

.project-card .img-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 25px;
    aspect-ratio: 16/9; /* Widescreen ratio as requested */
}

.project-card.side .img-wrapper {
    height: auto;
    width: 400px;
}

.project-card.active .img-wrapper {
    height: auto;
    width: 800px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.15);
}

.project-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease), filter 0.6s var(--ease);
}

.project-card:hover img {
    transform: scale(1.05);
    filter: brightness(1.1);
}

.expand-btn {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--white);
    color: var(--text-dark);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

.project-card h3 {
    font-size: 1.2rem;
    margin-top: 15px;
    margin-bottom: 5px;
    color: var(--text-dark);
}

.project-card p {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent);
}

.carousel-controls {
    display: none; /* Hide since text is now inside cards */
}

.active-project-info h3 {
    font-size: 2rem;
}

.active-project-info p {
    color: var(--accent);
    font-size: 14px;
    margin-bottom: 20px;
}

.slider-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
}

.nav-arrow {
    background: transparent;
    border: 1px solid rgba(0,0,0,0.1);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.drag-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-size: 12px;
    color: var(--text-light);
    border-top: 1px solid rgba(0,0,0,0.1);
    padding-top: 10px;
    width: 200px;
}

/* SECTION 3: BOOKING */
.booking-section {
    padding: 120px 5%;
    background-color: var(--bg-alt);
    display: flex;
    justify-content: center;
}

.booking-content-col {
    width: 100%;
    max-width: 1000px;
    text-align: center;
}

.booking-desc {
    color: var(--text-light);
    margin: 0 auto 40px;
    max-width: 600px;
}

.booking-form-card {
    text-align: left;
    background: var(--white);
    padding: 40px;
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    margin-bottom: 40px;
    position: relative;
    border: 1px solid rgba(0,0,0,0.05);
    overflow: hidden;
    --x: 0px;
    --y: 0px;
}

.booking-form-card::before {
    content: "";
    position: absolute;
    inset: -3px;
    background: radial-gradient(
        250px circle at var(--x) var(--y),
        var(--accent),
        transparent 80%
    );
    z-index: -1;
    opacity: 0;
    transition: opacity 0.4s ease;
}

.booking-form-card:hover::before {
    opacity: 1;
}

.booking-form-card::after {
    content: "";
    position: absolute;
    inset: 1px;
    background: var(--white);
    border-radius: 19px;
    z-index: -1;
}

/* Extra outer glow for AI feel */
.booking-form-card {
    transition: box-shadow 0.5s ease;
}

.booking-form-card:hover {
    box-shadow: 0 0 30px rgba(176, 146, 112, 0.15);
}

.form-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
}

.form-header h3 {
    font-size: 1.5rem;
}

.steps {
    font-size: 12px;
    color: var(--text-light);
    display: flex;
    align-items: center;
    gap: 5px;
}

.dot {
    width: 8px;
    height: 8px;
    background: #E0E0E0;
    border-radius: 50%;
}

.dot.active {
    background: var(--text-dark);
}

.form-grid {
    display: flex;
    gap: 40px;
}

.form-left, .form-right {
    flex: 1;
}

.input-label {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 15px;
}

.ai-sparkle {
    font-size: 10px;
    background: linear-gradient(135deg, #B09270, #D4AF37);
    color: white;
    padding: 2px 8px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 600;
    text-transform: uppercase;
}

.date-picker-wrap {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.ai-input {
    padding: 10px;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 8px;
    font-family: var(--font-sans);
    outline: none;
    background: var(--bg-main);
    cursor: pointer;
    transition: all 0.3s;
}

.ai-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 10px rgba(176, 146, 112, 0.2);
}

/* Word-by-word reveal */
.word-wrap {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
}
.word {
    display: inline-block;
}

.pills-grid {
    display: grid;
    gap: 8px;
}

.date-pills {
    grid-template-columns: repeat(5, 1fr);
    margin-bottom: 20px;
}

.time-pills {
    grid-template-columns: repeat(4, 1fr);
}

.pill {
    background: #f5f3f0;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 10px;
    padding: 10px 5px;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
}

.pill span {
    display: block;
    font-size: 10px;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.pill strong {
    font-size: 17px;
    font-weight: 600;
    color: var(--text-dark);
    line-height: 1;
}

.pill-time {
    background: #f5f3f0;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 10px;
    padding: 10px 6px;
    text-align: center;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s;
    color: var(--text-dark);
}

.pill:hover, .pill-time:hover {
    border-color: var(--accent);
    background: rgba(176,146,112,0.08);
}

.pill.active, .pill-time.active {
    background: var(--text-dark);
    color: var(--white);
    border-color: var(--text-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0,0,0,0.15);
}

.pill.active span {
    color: rgba(255,255,255,0.65);
}

.pill.active strong {
    color: white;
}

.input-group {
    margin-bottom: 20px;
}

.input-group label {
    display: block;
    font-size: 12px;
    color: var(--text-light);
    margin-bottom: 5px;
}

.input-group input, .input-group select {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 8px;
    font-family: var(--font-sans);
    outline: none;
    transition: all 0.3s var(--ease);
}

.input-group input:focus, .input-group select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 10px rgba(176, 146, 112, 0.2);
}

.features-row {
    display: flex;
    justify-content: space-between;
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 15px;
}

.icon-circle {
    width: 40px;
    height: 40px;
    background: rgba(176, 146, 112, 0.2);
    color: var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.feature-item h4 {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
}

.feature-item p {
    font-size: 11px;
    color: var(--text-light);
}

/* TRANSFORMATION REVEAL SECTION */
.reveal-section {
    padding: 120px 5%;
    background-color: var(--bg-main);
    display: flex;
    flex-direction: column;
    align-items: center;
}

.reveal-container {
    width: 100%;
    max-width: 1200px;
    margin: 40px auto;
}

.reveal-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 20px;
    overflow: hidden;
    cursor: ew-resize;
    box-shadow: 0 40px 80px rgba(0,0,0,0.1);
    background: #eee;
    touch-action: none;
}

.reveal-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}

.reveal-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
}

.layer-base {
    z-index: 1;
}

.layer-clear {
    z-index: 2;
}

.after-img-clear {
    filter: brightness(1.05); /* Premium brightness effect only */
}

.layer-before {
    z-index: 3;
    clip-path: inset(0 0 0 0); /* Fully visible initially */
}

.reveal-label {
    position: absolute;
    top: 30px;
    padding: 8px 20px;
    background: rgba(0, 0, 0, 0.4);
    color: white;
    font-size: 10px;
    letter-spacing: 3px;
    font-weight: 600;
    border-radius: 4px;
    backdrop-filter: blur(10px);
    z-index: 5;
    pointer-events: none;
}

.after-label {
    left: 30px;
}

.before-label {
    right: 30px;
}

.reveal-handle {
    position: absolute;
    top: 0;
    left: 0%; /* Initial position */
    width: 4px;
    height: 100%;
    background: white;
    z-index: 10;
    pointer-events: none;
    transform: translateX(-50%);
    box-shadow: 0 0 20px rgba(0,0,0,0.2);
}

.handle-line {
    position: absolute;
    top: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    background: white;
    transform: translateX(-50%);
    box-shadow: 0 0 10px rgba(0,0,0,0.2);
}

.handle-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 44px;
    height: 44px;
    background: white;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.reveal-wrapper:hover .handle-circle {
    transform: translate(-50%, -50%) scale(1.1);
}

.handle-inner {
    width: 4px;
    height: 4px;
    background: var(--text-dark);
    border-radius: 50%;
    box-shadow: -8px 0 0 var(--text-dark), 8px 0 0 var(--text-dark);
}

.reveal-footer-stats {
    display: flex;
    gap: 80px;
    margin-top: 40px;
    justify-content: center;
}

.reveal-stat {
    text-align: center;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-light);
}

.reveal-stat span {
